@model BodyViewModel

@if (Model.Results != null)
{
<div>
    @if (Model.Results.Courses.Count() > 0)
    {
        if (Model.FreeCourseSearch)
        {
            <p class="govuk-body">Showing <span class="fac-result-count">@String.Format("{0:n0}", Model.Results.ResultProperties.TotalResultCount)</span> free courses</p>
            <p id="national-results-message">Also explore <a id="allCourses" class="update-results" href="@Model.ChangeSearchLink"> different types of learning opportunities</a>.</p>
           
        }
        else
        {
            <p class="govuk-body">Showing all <span class="fac-result-count">@String.Format("{0:n0}", Model.Results.ResultProperties.TotalResultCount)</span> courses</p>
            <p id="free-courses-list">Also explore <a id="freeCourses" class="update-results" href="@Model.ChangeSearchLink"> free courses and qualifications for adults (19+) </a>.</p>
        }
        
        
        <hr class="govuk-section-break govuk-section-break--visible">
        <p>
    <div id="orderby-block" class="govuk-form-group">
        <div id="orderBy">
            <label class="result-region-header__sort-label govuk-label" aria-label="SelectedOrderValue" for="orderByInput" id="orderby-label">Sort by</label>
            <select asp-for="SideBar.SelectedOrderByValue" aria-label="SelectedOrderByValue" asp-items="Model.SideBar.OrderByOptions" class="govuk-select" name="SideBar.SelectedOrderByValue" id="orderBy-Input"></select>
        </div>
    </div>
    </p>
    }
</div>
}